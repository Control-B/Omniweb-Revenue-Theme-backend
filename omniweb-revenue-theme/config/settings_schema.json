[
  {
    "name": "theme_info",
    "theme_name": "Omniweb Revenue Theme",
    "theme_version": "1.0.0",
    "theme_author": "Omniweb",
    "theme_documentation_url": "https://omniweb.dev/docs",
    "theme_support_url": "https://omniweb.dev/support"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary color",
        "default": "#111111"
      },
      {
        "type": "color",
        "id": "color_button",
        "label": "Button / Accent color",
        "default": "#E63946"
      },
      {
        "type": "color",
        "id": "color_button_text",
        "label": "Button text color",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_button_hover",
        "label": "Button hover color",
        "default": "#C1121F"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Body text color",
        "default": "#1A1A1A"
      },
      {
        "type": "color",
        "id": "color_text_secondary",
        "label": "Secondary text color",
        "default": "#666666"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Page background",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_background_secondary",
        "label": "Secondary background",
        "default": "#F8F8F8"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border color",
        "default": "#E5E5E5"
      },
      {
        "type": "color",
        "id": "color_sale",
        "label": "Sale badge color",
        "default": "#E63946"
      },
      {
        "type": "color",
        "id": "color_star",
        "label": "Star rating color",
        "default": "#FFB800"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "inter_n7"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "inter_n4"
      },
      {
        "type": "range",
        "id": "font_body_size",
        "label": "Body font size",
        "min": 14,
        "max": 18,
        "step": 1,
        "unit": "px",
        "default": 15
      },
      {
        "type": "range",
        "id": "heading_scale",
        "label": "Heading scale",
        "min": 90,
        "max": 130,
        "step": 5,
        "unit": "%",
        "default": 100
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "label": "Page width",
        "min": 1000,
        "max": 1600,
        "step": 50,
        "unit": "px",
        "default": 1280
      },
      {
        "type": "range",
        "id": "spacing_sections",
        "label": "Section spacing",
        "min": 20,
        "max": 100,
        "step": 5,
        "unit": "px",
        "default": 60
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_max_width",
        "label": "Logo max width",
        "min": 80,
        "max": 300,
        "step": 10,
        "unit": "px",
        "default": 160
      },
      {
        "type": "checkbox",
        "id": "sticky_header",
        "label": "Enable sticky header",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_search",
        "label": "Show search",
        "default": true
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "16 x 16px .ico or .png"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          {
            "value": "drawer",
            "label": "Drawer"
          },
          {
            "value": "page",
            "label": "Page"
          }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "enable_cart_upsell",
        "label": "Show upsell in cart",
        "default": true
      },
      {
        "type": "text",
        "id": "cart_upsell_title",
        "label": "Cart upsell title",
        "default": "You might also like"
      },
      {
        "type": "collection",
        "id": "cart_upsell_collection",
        "label": "Cart upsell collection"
      }
    ]
  },
  {
    "name": "Product",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_product_reviews",
        "label": "Show reviews section",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_sticky_atc",
        "label": "Enable sticky add-to-cart",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_size_guide",
        "label": "Show size guide link",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "show_quantity_selector",
        "label": "Show quantity selector",
        "default": true
      }
    ]
  },
  {
    "name": "Social",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL"
      },
      {
        "type": "text",
        "id": "social_twitter",
        "label": "Twitter / X URL"
      },
      {
        "type": "text",
        "id": "social_youtube",
        "label": "YouTube URL"
      },
      {
        "type": "text",
        "id": "social_pinterest",
        "label": "Pinterest URL"
      }
    ]
  },
  {
    "name": "Animations",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_animations",
        "label": "Enable scroll animations",
        "default": true
      }
    ]
  },
  {
    "name": "AI Sales Widget",
    "settings": [
      {
        "type": "header",
        "content": "Omniweb AI Sales Widget"
      },
      {
        "type": "paragraph",
        "content": "Install the AI chat assistant on your store. Get your API URL and key from your Omniweb dashboard."
      },
      {
        "type": "checkbox",
        "id": "enable_ai_widget",
        "label": "Enable AI sales assistant",
        "default": false
      },
      {
        "type": "text",
        "id": "widget_api_url",
        "label": "Widget API URL",
        "info": "Your Omniweb API server URL, e.g. https://your-api.replit.app",
        "placeholder": "https://your-api.replit.app"
      },
      {
        "type": "text",
        "id": "widget_api_key",
        "label": "Widget API Key",
        "info": "Your widget API key from the Omniweb dashboard"
      }
    ]
  }
]