<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, height=device-height, minimum-scale=1.0">
  <meta name="theme-color" content="{{ settings.color_button }}">

  <link rel="canonical" href="{{ canonical_url }}">

  {% if settings.favicon != blank %}
    <link rel="shortcut icon" href="{{ settings.favicon | image_url: width: 32, height: 32 }}" type="image/png">
  {% endif %}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {% render 'social-meta-tags' %}

  {{ content_for_header }}

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ 'theme-variables.css' | asset_url | stylesheet_tag }}
</head>

<body class="template-{{ template.name | handle }}{% if customer %} customer-logged-in{% endif %}{% if settings.enable_animations %} animations-enabled{% endif %}">

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {% render 'cart-drawer' %}
  {% render 'quick-view-modal' %}

  <div id="overlay" class="overlay" aria-hidden="true"></div>

  {{ 'theme.js' | asset_url | script_tag }}

  {% comment %}
    Omniweb AI Sales Widget
    Configure in Theme Editor → Theme Settings → AI Sales Widget.
    Set your API URL and API key from your Omniweb dashboard.
  {% endcomment %}
  {% if settings.enable_ai_widget and settings.widget_api_url != blank and settings.widget_api_key != blank %}
    <script
      src="{{ settings.widget_api_url }}/widget.js"
      data-api-url="{{ settings.widget_api_url }}"
      data-api-key="{{ settings.widget_api_key }}"
      data-shop-id="{{ shop.permanent_domain }}"
      defer
    ></script>
    <script>
      window.__owContext = {
        pageType: {{ template.name | json }},
        shopName: {{ shop.name | json }}
      };
    </script>
  {% endif %}

  <script>
    window.shopUrl = '{{ shop.url }}';
    window.routes = {
      cart_url: '{{ routes.cart_url }}',
      cart_add_url: '{{ routes.cart_add_url }}',
      cart_change_url: '{{ routes.cart_change_url }}',
      cart_update_url: '{{ routes.cart_update_url }}',
      predictive_search_url: '{{ routes.predictive_search_url }}'
    };
    window.cartStrings = {
      error: `{{ 'sections.cart.cart_error' | t }}`,
      quantityError: `{{ 'sections.cart.cart_quantity_error_html' | t: quantity: '[quantity]' }}`
    };
    window.variantStrings = {
      addToCart: `{{ 'products.product.add_to_cart' | t }}`,
      soldOut: `{{ 'products.product.sold_out' | t }}`,
      unavailable: `{{ 'products.product.unavailable' | t }}`
    };
    window.moneyFormat = {{ shop.money_format | json }};
  </script>
</body>
</html>
